{
  "name": "ai-i18n",
  "version": "5.0.1",
  "description": "CLI for AI-assisted translation of i18next locale JSON, generate and diff catalogs (OpenAI / Anthropic).",
  "type": "module",
  "exports": {
    "./i18next": {
      "types": "./dist/i18next.d.ts",
      "import": "./dist/i18next.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anasassi119/ai-i18n.git"
  },
  "bin": {
    "ai-i18n": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/i18next.js",
    "dist/i18next.d.ts",
    "templates",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsup --config tsup.cli.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "i18n",
    "i18next",
    "translation",
    "cli",
    "localization",
    "openai"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0 <1",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.0",
    "i18next": "^24.2.0",
    "openai": "^4.104.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
